rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.email == 'irsukin@gmail.com';
    }

    function hasMember() {
      return signedIn() && exists(/databases/$(database)/documents/members/$(request.auth.uid));
    }

    function memberDoc() {
      return get(/databases/$(database)/documents/members/$(request.auth.uid));
    }

    function sameTenant(tenantId) {
      return hasMember()
        && memberDoc().data.tenantId == tenantId
        && memberDoc().data.status == 'Aktif';
    }

    match /members/{userId} {
      allow create: if signedIn() && request.auth.uid == userId;
      allow read, update: if signedIn() && request.auth.uid == userId;
      allow read, update, delete: if isAdmin();
    }

    match /licenses/{code} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /invites/{code} {
      allow read: if true;
      allow create, update, delete: if signedIn() || isAdmin();
    }

    match /tenants/{tenantId} {
      allow create: if signedIn();
      allow read, update, delete: if isAdmin();
      allow read, update: if sameTenant(tenantId);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
